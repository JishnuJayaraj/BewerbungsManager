# HR4U Job Search API
HR4U_TOKEN=replace-with-token
HR4U_BASE_URL=https://replace-with-api-host

# LLM (litellm) — per-task models, cost-aware. EU/Mistral is the GDPR-safe default.
LLM_DEFAULT_PROVIDER=mistral
LLM_DEFAULT_MODEL=replace-with-model
# Optional per-task overrides:
# LLM_GENERATE_MODEL=         # higher quality for artifacts (cover letter / portal answers)
# LLM_PARSE_MODEL=            # cheaper/faster for cv_parse / suggest
MISTRAL_API_KEY=
# ANTHROPIC_API_KEY=          # cloud providers opt-in
# OPENAI_API_KEY=

# OpenAI opt-in example for local .env:
# LLM_DEFAULT_PROVIDER=openai
# LLM_DEFAULT_MODEL=gpt-4-mini
# OPENAI_API_KEY=

# App
DATABASE_URL=sqlite:///./jobcraft.db
SINGLE_USER=true
